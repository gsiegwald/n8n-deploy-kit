# Copy this file to terraform.tfvars and fill in the values.
# terraform.tfvars is excluded from version control (.gitignore).

aws_region     = "eu-west-3"
project_name   = "n8n-deploy-aws"
instance_type  = "t3.small"

# Your public IP with /32 suffix — SSH will be restricted to this address.
# Detect it with: curl -s https://ifconfig.me
admin_ip       = "YOUR_PUBLIC_IP/32"

# Content of your SSH public key (not the path, the actual key string).
# Generate with: ssh-keygen -t ed25519 -f .ssh/n8n-deploy-aws_key
# Then: cat .ssh/n8n-deploy-aws_key.pub
ssh_public_key = "ssh-ed25519 AAAA..."

