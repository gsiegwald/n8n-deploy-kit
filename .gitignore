# ──────────────────────────────────────────────
# TERRAFORM
# ──────────────────────────────────────────────
 
# Local .terraform directories
.terraform/
 
# State files
*.tfstate
*.tfstate.*
 
# Crash logs
crash.log
crash.*.log
 
# Sensitive variable files
*.tfvars
*.tfvars.json
*.auto.tfvars
*.auto.tfvars.json
 
# Allow tfvars templates to be committed
!*.tfvars.example
 
# Override files (used for local resource overrides, not for version control)
override.tf
override.tf.json
*_override.tf
*_override.tf.json
 
# Terraform lock info (transient, generated by terraform apply)
.terraform.tfstate.lock.info
 
# Terraform CLI configuration
.terraformrc
terraform.rc

# Terraform plan files
*.tfplan
tfplan
plan.out
 
# ──────────────────────────────────────────────
# ANSIBLE
# ──────────────────────────────────────────────
 
# Generated inventory (contains IP + SSH key path)
*inventory.ini
 
# Retry files generated on failed plays
*.retry
 
# ──────────────────────────────────────────────
# ENVIRONMENT / SECRETS
# ──────────────────────────────────────────────
 
.env
**/.env
vault.yml
.home/
 
# ──────────────────────────────────────────────
# SSH KEYS & CERTIFICATES
# ──────────────────────────────────────────────
 
*.pem
*.key
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
.ssh/
 
# ──────────────────────────────────────────────
# PYTHON
# ──────────────────────────────────────────────
 
__pycache__/
.venv/
 
# ──────────────────────────────────────────────
# SYSTEM
# ──────────────────────────────────────────────
 
.DS_Store
Thumbs.db
