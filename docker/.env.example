# PostgreSQL
POSTGRES_DB=n8n
POSTGRES_USER=n8n
# Generated by Ansible on first deploy
POSTGRES_PASSWORD=

# n8n database connection
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=postgres
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=n8n
# Same as POSTGRES_PASSWORD — generated by Ansible
DB_POSTGRESDB_PASSWORD=

# n8n application
# Generated by Ansible — never change after first deploy
N8N_ENCRYPTION_KEY=
# Set dynamically from EC2 IP via sslip.io
N8N_HOST=
N8N_PROTOCOL=https
# Set dynamically from EC2 IP via sslip.io
WEBHOOK_URL=
N8N_PROXY_HOPS=1
